# ---- Venice AI (private reasoning; OpenAI-compatible) ----
# Key: https://venice.ai/settings/api   (fund a few $ of credits)
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
# Current private (zero-retention) default; confirm via GET /models/traits.
VENICE_MODEL=zai-org-glm-4.7

# ---- Chain (testnet) ----
# baseSepolia | sepolia
CHAIN=baseSepolia
# An RPC endpoint for the chosen testnet (e.g. from Alchemy/Infura/public RPC).
RPC_URL=

# ---- Demo signer (TESTNET ONLY) ----
# A throwaway testnet private key for scripts. NEVER use a real key; never commit .env.
SIGNER_PRIVATE_KEY=

# ---- 1Shot permissionless relayer (no API key needed) ----
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
